# =========================
# 🔥 MUST-HAVE CLEAN RULES
# =========================

# Build output (force ignore)
bin/
obj/
[Bb]in/
[Oo]bj/

# Compiled binaries
*.dll
*.exe

# Debug symbols
*.pdb

# Cache / temp
*.cache
*.log

# Visual Studio
.vs/
*.user
*.suo

# Node (if frontend exists)
node_modules/

# OS files
.DS_Store
Thumbs.db